---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { base } from '../lib/url';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	cs_area?: string[];
	concept?: string[];
	status?: string;
	stack?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, cs_area, concept, status } =
	Astro.props;
const AREA_LABEL: Record<string, string> = {
	os: 'os',
	arch: 'arch',
	network: 'network',
	'data-structures': 'ds',
	algorithms: 'algo',
};
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="post-head">
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(수정: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<div class="chips">
						{
							(cs_area ?? []).map((a) => (
								<a class="chip accent" href={`${base}#${a}`}>
									{AREA_LABEL[a] ?? a}
								</a>
							))
						}
						{(concept ?? []).map((c) => <span class="chip">{c}</span>)}
						{status && <span class="chip">{status}</span>}
					</div>
					<hr />
				</header>
				{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	.post-head h1 {
		margin: 0.3em 0 0.5em;
	}
	.post-head .date {
		color: var(--ink-soft);
	}
	.post-head .chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-bottom: 1.2em;
	}
	.post-head hr {
		margin: 0 0 1.5em;
	}
</style>

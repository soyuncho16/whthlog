---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;
---

<header>
	<nav>
		<a class="brand" href={base}>{SITE_TITLE}</a>
		<div class="links">
			<a href={`${base}about/`}>소개</a>
			<a href="https://github.com/soyuncho16/whthlog" target="_blank" rel="noopener">GitHub</a>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		border-bottom: 1px solid var(--line);
	}
	nav {
		max-width: 68ch;
		margin: 0 auto;
		padding: 0.9em 1em;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.brand {
		font-weight: 700;
		font-size: 1.05em;
		text-decoration: none;
		color: var(--ink);
	}
	.links {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	.links a {
		color: var(--ink-soft);
		text-decoration: none;
	}
	.links a:hover {
		color: var(--ink);
	}
</style>
